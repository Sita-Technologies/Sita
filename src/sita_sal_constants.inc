static const size_t k_sal_constant_count = sizeof(k_sal_constants)/sizeof(k_sal_constants[0]);

// Return the name of a constant whose NAME starts with `family_prefix`
// and whose VALUE equals `v`. Broader prefix = more candidates; pass
// "TBL_Fill" to restrict lookup to Fill* members only and avoid
// collisions with e.g. TBL_RowHdr_MarkEdits (both have value 1).
// Returns NULL if no constant matches. First match in declaration order
// wins — which mirrors the author-intended constant in every TD sample
// we've checked (e.g. 0 → MB_Ok, not MB_DefButton1 or MB_ApplModal).
static inline const char* _impl_resolve_sal_constant(const char* family_prefix, int64_t v) {
	if (!family_prefix) return nullptr;
	size_t plen = strlen(family_prefix);
	for (size_t i = 0; i < k_sal_constant_count; ++i) {
		if (k_sal_constants[i].value != v) continue;
		if (strncmp(k_sal_constants[i].name, family_prefix, plen) == 0)
			return k_sal_constants[i].name;
	}
	return nullptr;
}
